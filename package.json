{
  "name": "webapp-schulverwaltung",
  "version": "0.0.0",
  "homepage": "https://github.com/bkd-mba-fbi/webapp-schulverwaltung/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/bkd-mba-fbi/webapp-schulverwaltung/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bkd-mba-fbi/webapp-schulverwaltung.git"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:browserstack": "ng serve --host 0.0.0.0 --disable-host-check --port 8000",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build-and-copy-local": "pnpm build:prod && ./scripts/copy-to-portal.sh ../evento-portal/public/apps/webapp-schulverwaltung/",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCI",
    "test:watch": "ng test --browsers=ChromiumHeadless",
    "test:brief": "ng test --browsers=ChromiumHeadless --reporters brief",
    "test:coverage": "ng test --browsers=ChromiumHeadless --code-coverage --reporters coverage-istanbul",
    "lint": "ng lint",
    "format": "prettier --write \"./**/*\" --ignore-unknown",
    "format:upgrade": "pnpm add --save-exact prettier@latest && pnpm format",
    "preanalyze": "ng build --stats-json",
    "analyze": "npx webpack-bundle-analyzer dist/$(ng config defaultProject)/stats.json",
    "postanalyze": "rm dist/$(ng config defaultProject)/stats.json",
    "unused": "npx knip",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/localize": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@ng-select/ng-select": "^21.8.2",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "cropt": "^1.2.2",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "fp-ts": "^2.16.11",
    "io-ts": "^2.2.22",
    "io-ts-types": "^0.5.19",
    "lodash-es": "^4.18.1",
    "monocle-ts": "^2.3.13",
    "newtype-ts": "^0.3.5",
    "ngx-infinite-scroll": "^21.0.0",
    "pdfobject": "^2.3.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/language-service": "^21.2.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jasmine": "^6.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.13.2",
    "@types/pdfobject": "^2.2.5",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jasmine-core": "^6.3.0",
    "karma": "^6.4.4",
    "karma-brief-reporter": "^0.3.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage-istanbul-reporter": "^3.0.3",
    "karma-jasmine": "^5.1.0",
    "karma-spec-reporter": "^0.0.36",
    "lint-staged": "^17.0.8",
    "prettier": "3.8.4",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "./src/app/**/*.{ts,html}": "eslint",
    "**/*": "prettier --write --ignore-unknown"
  }
}
